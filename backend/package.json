{
  "name": "roboss-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "test": "tsx --test test/**/*.test.ts",
    "verify:system": "tsx scripts/system-verification.ts",
    "verify:system:local": "prisma generate && tsx scripts/system-verification.ts",
    "verify:env": "tsx scripts/verify-env.ts",
    "verify:production": "tsx scripts/production-readiness.ts",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:payment-provider": "tsx scripts/payment-provider-smoke.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.4",
    "@hono/node-server": "^1.14.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "hono": "^4.7.0",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.10.0",
    "stripe": "^22.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.18",
    "@types/ws": "^8.5.13",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
