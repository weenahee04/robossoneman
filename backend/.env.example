# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/roboss?schema=public"

# JWT
JWT_SECRET="replace-with-a-strong-32-plus-char-secret"
JWT_REFRESH_SECRET="replace-with-a-different-strong-32-plus-char-secret"
SCAN_TOKEN_SECRET="replace-with-a-dedicated-strong-32-plus-char-secret"
SCAN_TOKEN_TTL_SECONDS=300

# Clerk
# Fill these when migrating customer auth to Clerk.
CLERK_SECRET_KEY=""
CLERK_PUBLISHABLE_KEY=""
CLERK_JWT_KEY=""
CLERK_WEBHOOK_SECRET=""
CLERK_AUTH_MODE="legacy"

# LINE Login
LINE_CHANNEL_ID="your-line-channel-id"
LINE_CHANNEL_SECRET="your-line-channel-secret"
LINE_LIFF_ID=""
LINE_OFFICIAL_ACCOUNT_BASIC_ID=""
LINE_RICH_MENU_ID=""

# MQTT (IoT)
MQTT_BROKER_URL="mqtt://localhost:1883"
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_TOPIC_PREFIX="roboss"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
AUTH_ALLOW_DEV_LOGIN=true
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Payments
# `mock_promptpay` is for local/dev only.
# `generic_rest` is only a staging scaffold and is not an exact-match production adapter.
# Before opening production payment traffic, replace this with a real provider-specific adapter name.
BRANCH_PAYMENT_CREDENTIAL_SECRET=replace-with-a-strong-secret-for-credential-encryption
PAYMENT_PROVIDER_NAME=mock_promptpay
PAYMENT_PROVIDER_CREATE_URL=
PAYMENT_PROVIDER_VERIFY_URL=
PAYMENT_PROVIDER_VERIFY_METHOD=GET
PAYMENT_PROVIDER_API_KEY=
PAYMENT_PROVIDER_AUTH_HEADER=Authorization
PAYMENT_PROVIDER_AUTH_SCHEME=Bearer
PAYMENT_PROVIDER_CALLBACK_URL=
PAYMENT_PROVIDER_TIMEOUT_MS=10000
PAYMENT_PROVIDER_WEBHOOK_SECRET=change-me
PAYMENT_PROVIDER_WEBHOOK_SECRET_HEADER=x-payment-webhook-secret
PAYMENT_PROVIDER_SIGNATURE_SECRET=
PAYMENT_PROVIDER_SIGNATURE_HEADER=x-payment-signature
PAYMENT_PROVIDER_SIGNATURE_PREFIX=sha256=
PAYMENT_PROVIDER_SIGNATURE_ALGORITHM=sha256
PAYMENT_ALLOW_MANUAL_CONFIRM=true
SLIPMATE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Machine events / IoT
MACHINE_EVENT_SECRET=change-me-before-staging
ALLOW_SIMULATED_WASH=true
